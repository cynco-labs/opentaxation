# Convex Configuration
# Set automatically by `npx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Optional: Error tracking
VITE_ERROR_TRACKING_ENABLED=false

# Note: Configure Google OAuth in Convex Dashboard
# 1. Set AUTH_GOOGLE_ID and AUTH_GOOGLE_SECRET as Convex environment variables
# 2. Get credentials from Google Cloud Console → APIs & Services → Credentials
# 3. Add authorized redirect URI from Convex Auth setup
